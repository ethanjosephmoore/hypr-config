;; 4. Email Widget
(defwidget email-module []
  (box :class "widget-card" :orientation "v" :space-evenly false :style "margin: 0px; padding: 15px; background: #383c4a; border-radius: 0px;"
    (label :class "section-title" :text "Exchange Inbox" :halign "start" :style "margin-bottom: 12px; font-weight: bold; color: 5294e2; font-size: 15px;")
    
    (box :orientation "v" :space-evenly false
      (for mail in "${email_list}"
        (box :class "email-item" :orientation "h" :space-evenly false :style "margin-bottom: 10px; border-bottom: 1px solid #313244; padding-bottom: 8px;"
          (box :orientation "v" :space-evenly false :hexpand true
            (label :class "email-sender" :text "${mail.sender}" :halign "start" :style "font-weight: bold; font-size: 13px; color: #eff5fa")
            (label :class "email-subject" :text "${mail.subject}" :halign "start" :limit-width 28 :style "font-size: 11px; color: #7c818c;"))
          (label :class "email-time" :text "${mail.time}" :halign "end" :valign "start" :style "font-size: 10px; color: #7c818c;"))))))

;; 5. Lesson Timetable
(defwidget schedule_widget []
  (box :class "schedule-container" :orientation "v" :space-evenly false
    ;; This header now dynamically updates with "Today's Schedule (Week A)"
    (label :class "schedule-title" 
           :text "Today's Schedule (${today_lessons.week})" 
           :halign "start")
    
    ;; Notice we loop through today_lessons.lessons now
    (box :orientation "v" :space-evenly true :class "lessons-list"
      (for lesson in "${today_lessons.lessons}"
        (box :class "lesson-row" :orientation "h" :space-evenly false
          (label :class "period-number" :text "P${lesson.period}: " :width 40 :halign "start")
          (label :class "subject-name" :text "${lesson.subject}" :halign "start")
        )
      )
    )
  )
)

;; Variables & Polls
(defpoll time :interval "1s" "date '+%H:%M'")
(defpoll date :interval "10s" "date '+%A, %B %d'")
;; Reads the JSON generated by our python script
(defpoll email_list :interval "2m" :initial "[]" "cat ~/.config/eww/emails.json")

;; Forces the python script to run and refresh the cache file every 2 minutes
(defpoll email_sync :interval "2m" "python3 ~/.config/eww/scripts/fetch_emails.py &")

(defpoll today_lessons :interval "10m" :initial "[]" "python3 ~/.config/eww/scripts/get_schedule.py")

;; Fetch disk usage percentage for root "/" safely via bash
(defpoll disk_used :interval "10m"
  "df -h / | awk 'NR==2 {print $5}' | sed 's/%//'")

(defpoll current_volume :interval "1s"
  "wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2 * 100)}'")

(defpoll current_brightness :interval "1s"
  "brightnessctl -m | awk -F, '{print substr($4, 0, length($4)-1)}'")


;; Listening variable for instantaneous workspace updates
(deflisten active_workspace :initial "1"
  "~/.config/eww/scripts/get_workspaces.sh")



(defpoll assignments 
  :interval "1s" 
  :initial "[]"
  "python3 /home/ethanmoore/.config/eww/scripts/parse_deadlines.py")

;; Power Menu Widget
(defwidget powermenu []
  (box :class "powermenu-box" 
       :orientation "h" 
       :space-evenly false
    (button :class "power-btn sleep"    :onclick "systemctl suspend" "⏾")
    (button :class "power-btn restart"  :onclick "systemctl reboot" "⭮")
    (button :class "power-btn shutdown" :onclick "systemctl poweroff" "⏼")
    (button :class "power-btn logout"   :onclick "hyprctl dispatch exit" "󰈆")))

;; Main Resources Widget
(defwidget resources []
  (box :class "resources-card" :orientation "v" :space-evenly false :spacing 16
    
    ;; CPU
    (box :orientation "v" :space-evenly false :spacing 6
      (box :orientation "h"
        (label :class "res-label-title" :halign "start" :text "CPU Load")
        (label :class "res-label-val" :halign "end" :text "${round(EWW_CPU.avg, 0)}%"))
      (segmented_bar :value {EWW_CPU.avg}))

    ;; RAM
    (box :orientation "v" :space-evenly false :spacing 6
      (box :orientation "h"
        (label :class "res-label-title" :halign "start" :text "RAM Load")
        (label :class "res-label-val" :halign "end" :text "${round(EWW_RAM.used_mem_perc, 0)}%"))
      (segmented_bar :value {EWW_RAM.used_mem_perc}))

    ;; DISK
    (box :orientation "v" :space-evenly false :spacing 6
      (box :orientation "h"
        (label :class "res-label-title" :halign "start" :text "Disk Storage")
        (label :class "res-label-val" :halign "end" :text "${disk_used}%"))
      (segmented_bar :value disk_used))))


# Window Layout
width = 100%
height = 100%
border-width = 0
outline-width = 0
padding-left = 35%
padding-top = 35%
result-spacing = 25
num-results = 10

# Font
font = "Helvetica Neue"
font-size = 14

# Colors (Hex format: RRGGBBAA)
background-color = #404552cc
text-color = #eff5fa
selection-color = #5294e2

# Behavior
hide-cursor = true
text-cursor = false
